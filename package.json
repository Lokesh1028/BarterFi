{
  "name": "p2p-financial-nft-barter",
  "version": "1.0.0",
  "description": "P2P Financial NFT Barter Exchange - A decentralized platform for trading Financial NFTs",
  "private": true,
  "workspaces": [
    "contracts",
    "frontend"
  ],
  "scripts": {
    "contracts": "cd contracts && npm run compile",
    "contracts:test": "cd contracts && npm run test",
    "contracts:deploy": "cd contracts && npm run deploy",
    "frontend": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "dev": "concurrently \"npm run contracts:test\" \"npm run frontend\"",
    "build": "npm run contracts && npm run frontend:build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "author": "DeFi Strategist",
  "license": "MIT"
} 